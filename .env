# ── Backend Spring Boot (via proxy Vite en dev) ──
# Laisser VIDE : axios utilise /api/* relatif, proxifié par Vite → :8081
VITE_API_BASE_URL=

# ── Keycloak SSO (réseau interne Attijariwafa / VPN requis) ──
# VITE_KEYCLOAK_URL = la BASE du serveur d'auth,
# PAS l'URL de la console (.../admin/<realm>/console/).
VITE_KEYCLOAK_URL=https://keycloak-interne-rct.attijariwafa.net
VITE_KEYCLOAK_REALM=sdm_services_store
VITE_KEYCLOAK_CLIENT=trading-frontend

# ── Feature flags ──
VITE_ENABLE_REAL_TIME=true
VITE_DEBUG_MODE=false
